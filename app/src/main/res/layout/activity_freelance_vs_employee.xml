<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="25dp"
    android:background="#F4F7FA">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="שכיר או עצמאי?"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#1A237E"
        android:layout_gravity="right"
        android:layout_marginBottom="30dp"/>

    <EditText
        android:id="@+id/etEmployeeSalary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="שכר ברוטו נוכחי (₪)"
        android:inputType="number"
        android:textSize="20sp"
        android:textAlignment="center"
        android:padding="15dp"
        android:layout_marginBottom="20dp"/>

    <Button
        android:id="@+id/btnCalculate"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="חשב נקודת איזון"
        android:backgroundTint="#1A237E"
        android:layout_marginBottom="25dp"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="15dp"
        app:cardElevation="6dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:gravity="right">

            <TextView
                android:id="@+id/tvBreakEvenResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="התוצאה תופיע כאן"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#2E7D32"
                android:gravity="center"
                android:layout_marginBottom="15dp"/>

            <TextView
                android:id="@+id/tvDetails"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="פרטים נוספים..."
                android:textSize="16sp"
                android:textColor="#666666"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>